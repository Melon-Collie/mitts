<Project Sdk="Godot.NET.Sdk/4.6.0">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>HockeyGame</RootNamespace>
    <!-- Godot scans all .cs files under the project directory. Logic/Tests projects
         live in separate folders with their own csproj, so they won't conflict. -->
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="HockeyGame.Logic\HockeyGame.Logic.csproj" />
  </ItemGroup>
</Project>
